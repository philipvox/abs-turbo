# abs-turbo configuration
# Copy this file to .env and adjust values for your setup.
# All tools read from this file automatically.

# ==============================================================================
# AudiobookShelf
# ==============================================================================

# URL where ABS is accessible (from this server / from Docker network)
ABS_URL=http://localhost:8000

# Path to ABS SQLite database
# Docker: /config/absdatabase.sqlite (inside the proxy container)
# Bare metal: /opt/audiobookshelf/config/absdatabase.sqlite
ABS_DB=/config/absdatabase.sqlite

# Path to ABS metadata directory (where ABS stores cover images, etc.)
# Docker: /config/metadata (inside the proxy container)
# Bare metal: /opt/audiobookshelf/config/metadata
ABS_METADATA=/config/metadata

# Docker container name for ABS (used by inode-sync to restart after fixes)
ABS_CONTAINER=audiobookshelf

# ABS port (the port ABS listens on inside Docker or on the host)
ABS_PORT=8000

# Path to ABS config directory on the host (for Docker volume mapping)
ABS_CONFIG_DIR=./abs-config

# ==============================================================================
# Audiobook library
# ==============================================================================

# Path to your audiobook library on disk
# This is where ABS reads audio files from.
# If using SSHFS/NFS, this is the mount point.
AUDIOBOOKS_DIR=/mnt/audiobooks

# ==============================================================================
# Reverse proxy
# ==============================================================================

# Your domain (used in Caddy/nginx config templates)
# Use localhost:PORT for local-only access
DOMAIN=audiobooks.example.com

# ==============================================================================
# Moov proxy
# ==============================================================================

# Port for the moov proxy to listen on
PROXY_PORT=13379

# Directory for moov atom cache (permanent, ~10-15 bytes per second of audio)
MOOV_CACHE_DIR=/var/cache/abs-turbo/moov

# Directory for faststart file cache (LRU, recently played books)
FASTSTART_CACHE_DIR=/var/cache/abs-turbo/faststart

# Max size of faststart cache in GB
FASTSTART_MAX_GB=30

# Max age of faststart cache entries in days
FASTSTART_MAX_DAYS=30

# ==============================================================================
# Image cache
# ==============================================================================

# Directory for WebP cover/thumbnail cache
# Served directly by Caddy/nginx, bypassing ABS entirely
IMAGE_CACHE_DIR=/var/cache/image-cache

# ==============================================================================
# Inode sync (for SSHFS/NFS mounts)
# ==============================================================================

# Directory for the sentinel file that tracks mount inode changes
# Default: same directory as ABS_DB
SENTINEL_DIR=/var/cache/abs-turbo

# ==============================================================================
# Backups
# ==============================================================================

# Where to store database backups
ABS_BACKUP_DIR=/mnt/audiobooks/.abs-backups

# How many days to keep backups before automatic cleanup
BACKUP_RETENTION=30

# ==============================================================================
# Monitoring (Discord webhooks — optional)
# ==============================================================================

# Create Discord webhooks and paste URLs here
# Leave blank to disable a channel

# Per-topic channels
WEBHOOK_ABS=
WEBHOOK_SERVER=
WEBHOOK_STORAGE=
WEBHOOK_DOCKER=
WEBHOOK_CACHE=

# Critical alerts (high-priority channel)
WEBHOOK_CRITICAL=

# Server name shown in Discord message footers
SERVER_NAME=ABS Server

# ==============================================================================
# Monitoring thresholds
# ==============================================================================

CPU_WARN=85
CPU_CRIT=95
RAM_WARN=75
RAM_CRIT=90

# Storage: percentage FREE (alert when free space drops below)
STORAGE_WARN=20
STORAGE_CRIT=10

LOAD_WARN=5.0
LOAD_CRIT=8.0

# Cache volume: percentage USED
CACHE_WARN=90
CACHE_CRIT=95
CACHE_VOLUME=/var/cache/abs-turbo

# Minimum seconds between repeated alerts for the same issue
ALERT_COOLDOWN=900

# ==============================================================================
# Monitoring paths
# ==============================================================================

STATE_DIR=/var/lib/abs-turbo/state
LOG_FILE=/var/log/abs-turbo/monitor.log
