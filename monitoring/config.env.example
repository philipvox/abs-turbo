# =============================================================================
# abs-turbo monitoring — Configuration
# =============================================================================
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# All WEBHOOK_* values are Discord webhook URLs. Create them in your Discord
# server under Server Settings > Integrations > Webhooks.
# =============================================================================

# ---------------------------------------------------------------------------
# Server Identity
# ---------------------------------------------------------------------------
# A friendly name shown in Discord embed footers to identify this server.
SERVER_NAME="My ABS Server"

# ---------------------------------------------------------------------------
# Discord Webhook URLs
# ---------------------------------------------------------------------------
# Each channel gets its own webhook so you can route alerts to different
# Discord channels. Set any two to the same URL if you want them combined.

# AudiobookShelf-specific alerts (health checks, backups, scan events)
WEBHOOK_ABS="https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN"

# General server alerts (CPU, RAM, load)
WEBHOOK_SERVER="https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN"

# Storage alerts (disk space, mount failures)
WEBHOOK_STORAGE="https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN"

# Docker container alerts (stopped, restarting, unhealthy)
WEBHOOK_DOCKER="https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN"

# Critical alerts — high-priority channel for pages/outages
WEBHOOK_CRITICAL="https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN"

# Cache alerts (moov cache, faststart cache utilization)
WEBHOOK_CACHE="https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN"

# Daily digest — defaults to the SERVER webhook if not set separately
WEBHOOK_DIGEST="${WEBHOOK_DIGEST:-$WEBHOOK_SERVER}"

# ---------------------------------------------------------------------------
# AudiobookShelf Settings
# ---------------------------------------------------------------------------
# URL where ABS is reachable from this server (used for health checks)
ABS_URL="http://localhost:8000"

# Docker container name for ABS
ABS_CONTAINER="audiobookshelf"

# Path to the ABS SQLite database (inside the host, not the container)
ABS_DB="/opt/audiobookshelf/config/absdatabase.sqlite"

# Path to the ABS metadata directory
ABS_METADATA="/opt/audiobookshelf/metadata"

# ---------------------------------------------------------------------------
# Storage Paths
# ---------------------------------------------------------------------------
# Mount point for your audiobook storage (checked for mount status and space)
STORAGE_MOUNT="/mnt/audiobooks"

# Where to store database and metadata backups
BACKUP_DIR="/mnt/audiobooks/.abs-backups"

# How many days to keep backups before pruning
BACKUP_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Cache Paths (optional — only needed if using moov/faststart proxy)
# ---------------------------------------------------------------------------
# Docker volume or directory used by the moov cache
CACHE_VOLUME="/path/to/moov-cache"

# Faststart cache directory
CACHE_DIR="/var/cache/faststart-cache"

# ---------------------------------------------------------------------------
# Alert Thresholds
# ---------------------------------------------------------------------------
# CPU usage percentage
CPU_WARN=85
CPU_CRIT=95

# RAM usage percentage
RAM_WARN=75
RAM_CRIT=90

# Storage: percentage of FREE space remaining (alert when below these)
STORAGE_WARN=20
STORAGE_CRIT=10

# System load average (1-minute)
LOAD_WARN=5.0
LOAD_CRIT=8.0

# Cache utilization percentage (of allocated space)
CACHE_WARN=90
CACHE_CRIT=95

# ---------------------------------------------------------------------------
# Rate Limiting & Logging
# ---------------------------------------------------------------------------
# Minimum seconds between repeated alerts for the same issue
ALERT_COOLDOWN=900

# Directory for alert state files (used for cooldown tracking)
STATE_DIR="/opt/monitoring/state"

# Log file for all monitoring activity
LOG_FILE="/var/log/abs-turbo-monitor.log"
